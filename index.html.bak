<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>績效獎金產出模擬器</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f0f2f5; color: #333; padding: 20px; max-width: 1200px; margin: 0 auto; }
h1 { font-size: 26px; margin-bottom: 8px; color: #1a1a2e; }
.subtitle { color: #666; margin-bottom: 24px; font-size: 14px; }
.row { display: flex; gap: 20px; flex-wrap: wrap; }
.col { flex: 1; min-width: 300px; }
.card { background: #fff; border-radius: 12px; padding: 20px; margin-bottom: 16px; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
.card h2 { font-size: 16px; margin-bottom: 14px; color: #1a1a2e; padding-bottom: 8px; border-bottom: 2px solid #e8e8e8; }
.form-group { margin-bottom: 10px; }
.form-group label { display: block; font-size: 12px; color: #888; margin-bottom: 2px; }
.form-group input, .form-group select { width: 100%; padding: 8px 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
.form-group input:focus, .form-group select:focus { outline: none; border-color: #4361ee; }
.form-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.form-row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
.btn-primary { width: 100%; padding: 12px; background: #4361ee; color: #fff; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; margin-top: 8px; }
.btn-primary:hover { background: #3a56d4; }
.btn-secondary { padding: 8px 16px; background: #e8e8e8; color: #333; border: none; border-radius: 6px; font-size: 13px; cursor: pointer; }
.btn-secondary:hover { background: #d4d4d4; }
.btn-sm { padding: 4px 10px; background: #e74c3c; color: #fff; border: none; border-radius: 4px; font-size: 12px; cursor: pointer; }
.btn-sm:hover { background: #c0392b; }
.btn-add { padding: 6px 14px; background: #27ae60; color: #fff; border: none; border-radius: 4px; font-size: 12px; cursor: pointer; margin-top: 4px; }
.btn-add:hover { background: #219a52; }
.tab-bar { display: flex; gap: 0; margin-bottom: 16px; background: #e8e8e8; border-radius: 8px; overflow: hidden; }
.tab-btn { flex: 1; padding: 10px; border: none; background: transparent; font-size: 13px; cursor: pointer; font-weight: 500; transition: all .2s; }
.tab-btn.active { background: #4361ee; color: #fff; }
.result-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px,1fr)); gap: 8px; margin: 12px 0; }
.result-item { background: #f8f9fa; border-radius: 8px; padding: 10px; text-align: center; }
.result-item .label { font-size: 11px; color: #888; }
.result-item .value { font-size: 18px; font-weight: 700; margin-top: 2px; }
.result-item.highlight { background: #4361ee; color: #fff; }
.result-item.highlight .label { color: rgba(255,255,255,.7); }
.result-item.danger { background: #e74c3c; color: #fff; }
.result-item.danger .label { color: rgba(255,255,255,.7); }
.result-item.success { background: #27ae60; color: #fff; }
.result-item.success .label { color: rgba(255,255,255,.7); }
.result-item.gold { background: #f39c12; color: #fff; }
.result-item.gold .label { color: rgba(255,255,255,.7); }
.breakdown-table { width: 100%; border-collapse: collapse; font-size: 13px; margin: 8px 0; }
.breakdown-table th { text-align: left; font-size: 11px; color: #888; padding: 5px 8px; border-bottom: 2px solid #eee; }
.breakdown-table td { padding: 6px 8px; border-bottom: 1px solid #eee; }
.breakdown-table .text-right { text-align: right; }
.breakdown-table .total-row { background: #eef2ff; font-weight: 600; }
.breakdown-table .deduction-row { background: #fff5f5; color: #e74c3c; }
.breakdown-table .accelerate-row { background: #e8f8f0; }
.breakdown-table .decelerate-row { background: #fff8e1; }
.breakdown-table .cap-row { background: #fff0e0; color: #e67e22; }
.warning-box { background: #fff8e1; border-left: 4px solid #ffc107; padding: 12px; border-radius: 6px; margin: 8px 0; font-size: 13px; }
.success-box { background: #e8f8f0; border-left: 4px solid #27ae60; padding: 12px; border-radius: 6px; margin: 8px 0; font-size: 13px; }
.danger-box { background: #fff0f0; border-left: 4px solid #e74c3c; padding: 12px; border-radius: 6px; margin: 8px 0; font-size: 13px; }
.health-meter { display: flex; gap: 8px; margin: 8px 0; flex-wrap: wrap; }
.health-item { flex: 1; min-width: 140px; padding: 10px; border-radius: 8px; text-align: center; font-size: 13px; }
.health-item .val { font-size: 18px; font-weight: 700; }
.top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.step-table { width: 100%; border-collapse: collapse; margin: 6px 0; }
.step-table th { text-align: left; font-size: 11px; color: #888; padding: 4px 6px; border-bottom: 1px solid #ddd; }
.step-table td { padding: 4px 6px; vertical-align: middle; }
.step-table input { width: 70px; padding: 5px 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px; }
.step-table input:focus { outline: none; border-color: #4361ee; }
.step-hint { font-size: 11px; color: #aaa; margin: 4px 0 8px 0; }
.sweet-spot-vis { margin: 8px 0; padding: 12px; background: #f8f9fa; border-radius: 8px; font-size: 13px; }
.sweet-spot-vis .bar { display: flex; height: 20px; border-radius: 10px; overflow: hidden; margin: 4px 0; }
.sweet-spot-vis .bar-seg { flex: 1; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; color: #fff; }
@media (max-width: 600px) {
  .form-row2, .form-row3 { grid-template-columns: 1fr; }
  .result-grid { grid-template-columns: 1fr 1fr; }
  .step-table input { width: 60px; }
}
</style>
</head>
<body>

<div class="top-bar">
  <div>
    <h1>績效獎金產出模擬器</h1>
    <div class="subtitle">動態門檻 · 甜蜜點曲線 · 封頂制 · CSAT 調節 · Clawback 扣回</div>
  </div>
  <button class="btn-secondary" onclick="loadExample()">載入範例</button>
</div>

<!-- Tab -->
<div class="tab-bar">
  <button class="tab-btn active" onclick="switchTab('calc',this)">計算器</button>
  <button class="tab-btn" onclick="switchTab('logic',this)">邏輯與公式</button>
</div>

<!-- ====== 計算器 Tab ====== -->
<div id="tab-calc">
<div class="row">
  <!-- 左欄：輸入 -->
  <div class="col">
    <div class="card">
      <h2>基本設定</h2>
      <div class="form-row2">
        <div class="form-group">
          <label>職務形狀</label>
          <select id="jobType">
            <option value="上山型">上山型（業務/銷售）</option>
            <option value="平路型">平路型（行政/管理）</option>
            <option value="下山型">下山型（研發/技術）</option>
          </select>
        </div>
        <div class="form-group">
          <label>獎金類型</label>
          <select id="bonusType">
            <option value="commission">銷售佣金制</option>
            <option value="mbo">MBO/KPI 目標管理</option>
            <option value="comprehensive">年度綜合獎金</option>
          </select>
        </div>
      </div>
      <div class="form-row3">
        <div class="form-group">
          <label>底薪（年/萬）</label>
          <input type="number" id="baseSalary" value="120" min="0" step="1">
        </div>
        <div class="form-group">
          <label>預期獎金（年/萬）</label>
          <input type="number" id="targetBonus" value="120" min="0" step="1">
        </div>
        <div class="form-group">
          <label>法定外加成本 %</label>
          <input type="number" id="overheadRate" value="20" min="0" step="1">
        </div>
      </div>
    </div>

    <div class="card">
      <h2>業績目標</h2>
      <div class="form-row2">
        <div class="form-group">
          <label>年度目標（萬）</label>
          <input type="number" id="quota" value="1440" min="0" step="1">
        </div>
        <div class="form-group">
          <label>實際達成（萬）</label>
          <input type="number" id="actual" value="1800" min="0" step="1">
        </div>
      </div>
    </div>

    <div class="card">
      <h2>階梯門檻設定 <span style="font-size:12px;color:#888;font-weight:400;">（提撥率由低到高，可自由增減）</span></h2>
      <div class="step-hint">各區間的提撥率應逐階遞增，最後一階為加速器</div>
      <table class="step-table" id="stepTable">
        <thead><tr><th>區間</th><th>門檻 (萬)</th><th>提撥率 %</th><th></th></tr></thead>
        <tbody id="stepBody"></tbody>
      </table>
      <button class="btn-add" onclick="addStepRow()">+ 新增區間</button>
    </div>

    <div class="card">
      <h2>甜蜜點與封頂設定</h2>
      <div class="form-row3">
        <div class="form-group">
          <label>甜蜜點 (萬)</label>
          <input type="number" id="sweetSpot" value="1500" min="0" step="1">
        </div>
        <div class="form-group">
          <label>過甜蜜點提撥率 %</label>
          <input type="number" id="decelRate" value="2" min="0" step="0.5">
        </div>
        <div class="form-group">
          <label>獎金上限 (萬)</label>
          <input type="number" id="bonusCap" value="200" min="0" step="1">
        </div>
      </div>
      <div class="sweet-spot-vis" id="curvePreview">
        <div style="font-size:12px;color:#888;">曲線預覽（提撥率走勢）</div>
        <div class="bar" id="curveBar"></div>
      </div>
    </div>

    <div class="card">
      <h2>銷售成本</h2>
      <div class="form-row2">
        <div class="form-group">
          <label>銷售成本 COGS %</label>
          <input type="number" id="cogsRate" value="20" min="0" step="1">
        </div>
        <div class="form-group">
          <label>毛利佣金比例 %</label>
          <input type="number" id="grossMarginRate" value="15" min="0" step="1">
        </div>
      </div>
    </div>

    <div class="card">
      <h2>KPI / CSAT 調節</h2>
      <div class="form-row2">
        <div class="form-group">
          <label>KPI 綜合得分（0-1.2）</label>
          <input type="number" id="kpiScore" value="0.95" min="0" step="0.01">
        </div>
        <div class="form-group">
          <label>KPI 權重 %</label>
          <input type="number" id="kpiWeight" value="100" min="0" max="100" step="1">
        </div>
      </div>
      <div class="form-row2">
        <div class="form-group">
          <label>CSAT 目標（/5）</label>
          <input type="number" id="csatTarget" value="4.5" min="0" step="0.1">
        </div>
        <div class="form-group">
          <label>CSAT 實際（/5）</label>
          <input type="number" id="csatActual" value="4.2" min="0" step="0.1">
        </div>
      </div>
      <div class="form-row2">
        <div class="form-group">
          <label>CSAT 未達標折扣 %</label>
          <input type="number" id="csatPenalty" value="10" min="0" step="1">
        </div>
        <div class="form-group">
          <label>行為職能係數（0.8-1.2）</label>
          <input type="number" id="behaviorMod" value="1.0" min="0.8" max="1.2" step="0.05">
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Clawback 追回設定</h2>
      <div class="form-row2">
        <div class="form-group">
          <label>該筆訂單金額（萬）</label>
          <input type="number" id="cbAmount" value="120" min="0" step="1">
        </div>
        <div class="form-group">
          <label>佣金提撥率 %</label>
          <input type="number" id="cbRate" value="10" min="0" step="1">
        </div>
      </div>
      <div class="form-row2">
        <div class="form-group">
          <label>合約月數</label>
          <input type="number" id="cbTotalMonths" value="12" min="1" step="1">
        </div>
        <div class="form-group">
          <label>已履行月數</label>
          <input type="number" id="cbFulfilledMonths" value="4" min="0" step="1">
        </div>
      </div>
    </div>

    <button class="btn-primary" onclick="calculate()">計算獎金</button>
  </div>

  <!-- 右欄：結果 -->
  <div class="col">
    <div class="card">
      <h2>獎金摘要</h2>
      <div id="resultSummary">
        <div class="result-grid" id="summaryGrid">
          <div class="result-item"><div class="label">達成率</div><div class="value" id="rAchieve">—</div></div>
          <div class="result-item highlight"><div class="label">最終獎金</div><div class="value" id="rFinalBonus">—</div></div>
          <div class="result-item gold"><div class="label">甜蜜點獎金</div><div class="value" id="rSweetBonus">—</div></div>
          <div class="result-item"><div class="label">原始佣金</div><div class="value" id="rGrossCommission">—</div></div>
          <div class="result-item danger"><div class="label">Clawback 扣回</div><div class="value" id="rClawback">—</div></div>
          <div class="result-item"><div class="label">邊際提撥率</div><div class="value" id="rMarginalRate">—</div></div>
        </div>
        <div class="result-grid">
          <div class="result-item success"><div class="label">實領年薪</div><div class="value" id="rTotalPay">—</div></div>
          <div class="result-item"><div class="label">勞動分配率</div><div class="value" id="rLaborRate">—</div></div>
          <div class="result-item"><div class="label">Compa-Ratio</div><div class="value" id="rCompaRatio">—</div></div>
          <div class="result-item"><div class="label">距離甜蜜點</div><div class="value" id="rSweetGap">—</div></div>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>階梯獎金明細</h2>
      <table class="breakdown-table" id="tierTable">
        <thead><tr><th>區間</th><th>業績範圍</th><th>業績金額</th><th>提撥率</th><th>獎金</th></tr></thead>
        <tbody id="tierBody"></tbody>
      </table>
    </div>

    <div class="card">
      <h2>甜蜜點曲線</h2>
      <div id="curveDetail"></div>
    </div>

    <div class="card">
      <h2>調節與扣回明細</h2>
      <table class="breakdown-table" id="adjustTable">
        <thead><tr><th>項目</th><th>調整前</th><th>調整</th><th>調整後</th></tr></thead>
        <tbody id="adjustBody"></tbody>
      </table>
    </div>

    <div class="card">
      <h2>財務健康檢查</h2>
      <div id="healthCheck"></div>
    </div>
  </div>
</div>
</div>

<!-- ====== 邏輯公式 Tab ====== -->
<div id="tab-logic" style="display:none">
<div class="card">
<h2>一、銷售佣金制（動態階梯 + 甜蜜點曲線）</h2>
<table class="breakdown-table">
  <tr><th>項目</th><th>公式</th><th>說明</th></tr>
  <tr><td>年度目標</td><td>Quota = OTE × (4~6倍)</td><td>以 TCO（含法定成本）為基準，確保勞動分配率 ≤ 50%</td></tr>
  <tr><td>階梯門檻</td><td>各區間遞增提撥率</td><td>每個區間各自的金額 × 對應提撥率，固定成本回收期提撥率最低</td></tr>
  <tr><td>加速器</td><td>最後門檻~甜蜜點 × 加速器率</td><td>利潤分享期，提撥率為階梯中的最高值</td></tr>
  <tr><td>甜蜜點遞減</td><td>超過甜蜜點 × 遞減提撥率</td><td>過了甜蜜點後提撥率降低，引導業務在甜蜜點附近達成，避免過度激勵</td></tr>
  <tr><td>封頂制</td><td>最終獎金 ≤ 獎金上限</td><td>設有硬上限，控制總薪酬成本</td></tr>
  <tr><td>毛利佣金制</td><td>(營收-COGS) × 佣金率</td><td>防止過度打折，引導高毛利銷售</td></tr>
</table>
</div>

<div class="card">
<h2>二、MBO/KPI 目標管理型</h2>
<table class="breakdown-table">
  <tr><th>項目</th><th>公式</th><th>說明</th></tr>
  <tr><td>綜合評分</td><td>獎金基數 × Σ(KPIᵢ×Wᵢ) × 行為係數</td><td>加權係數總和 100%，行為係數調節數字達標但不當行為</td></tr>
  <tr><td>生產超額分享</td><td>(實際產量-基準) × 盈餘分享率</td><td>需搭配品質門檻，良率不足則扣減</td></tr>
</table>
</div>

<div class="card">
<h2>三、年度綜合獎金</h2>
<table class="breakdown-table">
  <tr><th>項目</th><th>公式</th><th>說明</th></tr>
  <tr><td>綜合核算</td><td>核定天數×績效係數×日薪 - 考勤積數 + 訓練積數</td><td>績效係數：優等1.2~1.5、甲等1.0、乙等0.8</td></tr>
</table>
</div>

<div class="card">
<h2>四、品質調節與 Clawback</h2>
<table class="breakdown-table">
  <tr><th>項目</th><th>公式</th><th>說明</th></tr>
  <tr><td>CSAT 調節</td><td>計算獎金 × CSAT 加權係數</td><td>未達門檻則打折，重大申訴一票否決</td></tr>
  <tr><td>Clawback 追回</td><td>已發佣金×(未履行月數/總月數)</td><td>SaaS/金融/房仲，防止短期道德風險</td></tr>
  <tr><td>勞動分配率</td><td>人事費總額 ÷ 營業毛利</td><td>理想 ≤ 50%，超過 61% 為經營警訊</td></tr>
  <tr><td>Compa-Ratio</td><td>實際薪資 ÷ 薪資中點</td><td>< 0.8 注意人才流失風險</td></tr>
</table>
</div>
</div>

<script>
function switchTab(name, btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-calc').style.display = name === 'calc' ? '' : 'none';
  document.getElementById('tab-logic').style.display = name === 'logic' ? '' : 'none';
}

function n(v) { return parseFloat(v) || 0; }
function fmt(v) { return 'NT$' + Math.round(v).toLocaleString(); }
function fmtW(v) { return Math.round(v).toLocaleString() + ' 萬'; }

// === 動態階梯門檻 ===
function addStepRow(threshold, rate) {
  const tbody = document.getElementById('stepBody');
  const row = document.createElement('tr');
  const idx = tbody.children.length;
  const t = threshold !== undefined ? threshold : '';
  const r = rate !== undefined ? rate : '';
  row.innerHTML = `
    <td style="font-size:12px;color:#888;">第${idx + 1}階</td>
    <td><input type="number" class="step-threshold" value="${t}" min="0" step="1" placeholder="門檻"></td>
    <td><input type="number" class="step-rate" value="${r}" min="0" step="0.5" placeholder="%"></td>
    <td><button class="btn-sm" onclick="removeStepRow(this)">−</button></td>
  `;
  tbody.appendChild(row);
}

function removeStepRow(btn) {
  const row = btn.parentElement.parentElement;
  row.parentElement.removeChild(row);
  // 重新編號
  Array.from(document.getElementById('stepBody').children).forEach((r, i) => {
    r.cells[0].textContent = '第' + (i + 1) + '階';
  });
}

function getSteps() {
  const rows = document.getElementById('stepBody').children;
  const steps = [];
  let prev = 0;
  for (const row of rows) {
    const t = n(row.querySelector('.step-threshold').value);
    const r = n(row.querySelector('.step-rate').value);
    if (t > 0 && r > 0) {
      steps.push({ threshold: t, rate: r / 100, label: prev + ' ~ ' + t + ' 萬' });
      prev = t;
    }
  }
  return steps;
}

function curvePreview() {
  const steps = getSteps();
  const sweetSpot = n(document.getElementById('sweetSpot').value);
  const decelRate = n(document.getElementById('decelRate').value);
  const bar = document.getElementById('curveBar');
  if (steps.length === 0 || sweetSpot <= 0) {
    bar.innerHTML = '<div style="font-size:10px;color:#aaa;text-align:center;width:100%;">請填入門檻資料</div>';
    return;
  }
  const lastThresh = steps[steps.length - 1].threshold;
  const maxRate = Math.max(...steps.map(s => s.rate * 100), decelRate);
  const segments = [];
  // Step segments
  for (const s of steps) {
    segments.push({ label: (s.rate * 100).toFixed(1) + '%', w: s.rate * 100 / maxRate, color: '#4361ee' });
  }
  // Accel segment if sweetSpot > lastThresh
  const accelRate = steps[steps.length - 1].rate * 100;
  if (sweetSpot > lastThresh) {
    segments.push({ label: accelRate.toFixed(1) + '%', w: accelRate / maxRate, color: '#27ae60' });
  }
  // Decel segment
  segments.push({ label: decelRate.toFixed(1) + '%', w: decelRate / maxRate, color: '#e67e22' });
  const totalW = segments.reduce((s, seg) => s + seg.w, 0);
  bar.innerHTML = segments.map(seg =>
    '<div class="bar-seg" style="flex:' + seg.w + ';background:' + seg.color + '">' + seg.label + '</div>'
  ).join('');
}

// === 主要計算 ===
function calculate() {
  const baseSalary = n(document.getElementById('baseSalary').value);
  const targetBonus = n(document.getElementById('targetBonus').value);
  const overhead = n(document.getElementById('overheadRate').value) / 100;
  const quota = n(document.getElementById('quota').value);
  const actual = n(document.getElementById('actual').value);
  const cogs = n(document.getElementById('cogsRate').value) / 100;
  const gmRate = n(document.getElementById('grossMarginRate').value) / 100;
  const kpiScore = n(document.getElementById('kpiScore').value);
  const kpiWeight = n(document.getElementById('kpiWeight').value) / 100;
  const csatTarget = n(document.getElementById('csatTarget').value);
  const csatActual = n(document.getElementById('csatActual').value);
  const csatPenalty = n(document.getElementById('csatPenalty').value) / 100;
  const behaviorMod = n(document.getElementById('behaviorMod').value);
  const cbAmt = n(document.getElementById('cbAmount').value);
  const cbRate = n(document.getElementById('cbRate').value) / 100;
  const cbTotal = n(document.getElementById('cbTotalMonths').value);
  const cbFulfilled = n(document.getElementById('cbFulfilledMonths').value);
  const sweetSpot = n(document.getElementById('sweetSpot').value);
  const decelRate = n(document.getElementById('decelRate').value) / 100;
  const bonusCap = n(document.getElementById('bonusCap').value);

  const steps = getSteps();
  const ote = baseSalary + targetBonus;
  const tco = ote * (1 + overhead);
  const achieveRate = actual / quota;
  const grossProfit = actual * (1 - cogs);
  const gmCommission = grossProfit * gmRate;

  let bonus = 0;
  let remaining = actual;
  const tiers = [];

  // Step 1: Apply each bracket
  let prevThreshold = 0;
  let lastStepRate = 0;
  for (const step of steps) {
    const bandAmt = Math.max(0, Math.min(remaining, step.threshold - prevThreshold));
    if (bandAmt <= 0) {
      prevThreshold = step.threshold;
      lastStepRate = step.rate;
      continue;
    }
    const bandBonus = bandAmt * step.rate;
    bonus += bandBonus;
    tiers.push({
      name: step.label,
      range: prevThreshold + ' ~ ' + step.threshold + ' 萬',
      amt: bandAmt,
      rate: (step.rate * 100).toFixed(1) + '%',
      bonus: bandBonus,
      cls: ''
    });
    remaining -= bandAmt;
    prevThreshold = step.threshold;
    lastStepRate = step.rate;
  }

  // Step 2: Accelerator zone (from last threshold to sweet spot)
  let accelRate = lastStepRate;
  let accelAmt = 0;
  let accelBonus = 0;
  if (remaining > 0 && sweetSpot > prevThreshold) {
    accelAmt = Math.min(remaining, sweetSpot - prevThreshold);
    if (accelAmt > 0) {
      accelBonus = accelAmt * accelRate;
      bonus += accelBonus;
      tiers.push({
        name: '加速器',
        range: prevThreshold + ' ~ ' + sweetSpot + ' 萬',
        amt: accelAmt,
        rate: (accelRate * 100).toFixed(1) + '%',
        bonus: accelBonus,
        cls: 'accelerate-row'
      });
      remaining -= accelAmt;
    }
  }

  // Step 3: Deceleration zone (after sweet spot)
  let decelAmt = 0;
  let decelBonus = 0;
  if (remaining > 0 && sweetSpot > 0) {
    decelAmt = remaining;
    decelBonus = decelAmt * decelRate;
    bonus += decelBonus;
    tiers.push({
      name: '甜蜜點後 (遞減)',
      range: sweetSpot + ' 萬 以上',
      amt: decelAmt,
      rate: (decelRate * 100).toFixed(1) + '%',
      bonus: decelBonus,
      cls: 'decelerate-row'
    });
    remaining = 0;
  }

  const rawCommission = bonus;

  // Sweet spot bonus calculation (what would bonus be AT the sweet spot)
  let sweetBonus = 0;
  let rem = Math.min(actual, sweetSpot);
  let pt = 0;
  for (const step of steps) {
    const ba = Math.max(0, Math.min(rem, step.threshold - pt));
    if (ba <= 0) { pt = step.threshold; continue; }
    sweetBonus += ba * step.rate;
    rem -= ba;
    pt = step.threshold;
  }
  if (rem > 0) {
    sweetBonus += rem * accelRate;
  }

  // Apply cap
  const cappedCommission = bonusCap > 0 ? Math.min(rawCommission, bonusCap) : rawCommission;
  const capHit = bonusCap > 0 && rawCommission > bonusCap;
  const capDeduction = capHit ? rawCommission - bonusCap : 0;

  // === KPI 調節 ===
  const kpiAdjusted = cappedCommission * (kpiScore * kpiWeight);

  // === 行為職能係數 ===
  const behaviorAdjusted = kpiAdjusted * behaviorMod;

  // === CSAT 品質門檻 ===
  let csatAdjusted = behaviorAdjusted;
  let csatNote = '';
  if (csatActual < csatTarget) {
    const factor = 1 - csatPenalty;
    csatAdjusted = behaviorAdjusted * factor;
    csatNote = 'CSAT ' + csatActual.toFixed(1) + '/' + csatTarget.toFixed(1) + ' 未達標，打 ' + (factor * 100).toFixed(0) + '%';
  } else {
    csatNote = 'CSAT ' + csatActual.toFixed(1) + '/' + csatTarget.toFixed(1) + ' 達標';
  }

  // === Clawback ===
  let clawbackAmt = 0;
  if (cbTotal > 0 && cbFulfilled < cbTotal) {
    const unfulfilledRatio = (cbTotal - cbFulfilled) / cbTotal;
    const originalComm = cbAmt * cbRate;
    clawbackAmt = originalComm * unfulfilledRatio;
  }

  const finalBonus = Math.max(csatAdjusted - clawbackAmt, 0);
  const totalPay = baseSalary + finalBonus;
  const totalPayMonthly = totalPay / 12;

  // === 財務健康 ===
  const totalPersonnelCost = tco;
  const laborRate = grossProfit > 0 ? (totalPersonnelCost / grossProfit) * 100 : 0;
  const compaRatio = ote > 0 ? (totalPay / ote) : 0;

  // Sweet spot gap
  const sweetGap = actual > 0 ? ((actual - sweetSpot) / sweetSpot * 100) : 0;

  // Marginal rate at current performance level
  let marginalRate = 0;
  if (actual > sweetSpot && sweetSpot > 0) {
    marginalRate = decelRate * 100;
  } else if (actual > 0 && steps.length > 0) {
    const lastThreshold = steps[steps.length - 1].threshold;
    if (actual > lastThreshold) {
      marginalRate = accelRate * 100;
    } else {
      // Find which step the actual falls in
      let prev = 0;
      for (const s of steps) {
        if (actual <= s.threshold) {
          marginalRate = s.rate * 100;
          break;
        }
        prev = s.threshold;
      }
    }
  }

  // === Render results ===
  document.getElementById('rAchieve').textContent = (achieveRate * 100).toFixed(1) + '%';
  document.getElementById('rFinalBonus').textContent = fmtW(finalBonus);
  document.getElementById('rSweetBonus').textContent = fmtW(sweetBonus);
  document.getElementById('rGrossCommission').textContent = fmtW(rawCommission);
  document.getElementById('rClawback').textContent = clawbackAmt > 0 ? '-' + fmtW(clawbackAmt) : 'NT$0';
  document.getElementById('rTotalPay').textContent = fmtW(totalPay);
  document.getElementById('rLaborRate').textContent = laborRate.toFixed(1) + '%';
  document.getElementById('rCompaRatio').textContent = compaRatio.toFixed(2);
  document.getElementById('rSweetGap').textContent = (sweetGap >= 0 ? '+' : '') + sweetGap.toFixed(1) + '%';
  document.getElementById('rMarginalRate').textContent = marginalRate.toFixed(1) + '%';

  // 階梯明細
  const tbody = document.getElementById('tierBody');
  tbody.innerHTML = tiers.map(t =>
    `<tr class="${t.cls}"><td>${t.name}</td><td>${t.range}</td><td class="text-right">${fmtW(t.amt)}</td><td class="text-right">${t.rate}</td><td class="text-right">${fmtW(t.bonus)}</td></tr>`
  ).join('');

  // Cap row
  if (capHit) {
    tbody.innerHTML += `<tr class="cap-row"><td>封頂扣減</td><td>超過獎金上限 (${fmtW(bonusCap)})</td><td class="text-right">—</td><td class="text-right">—</td><td class="text-right">-${fmtW(capDeduction)}</td></tr>`;
  }

  tbody.innerHTML += `<tr class="total-row"><td colspan="4" class="text-right">佣金合計</td><td class="text-right">${fmtW(Math.min(rawCommission, bonusCap > 0 ? bonusCap : Infinity))}</td></tr>`;

  // 甜蜜點曲線
  const curveHtml = `
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin:4px 0;">
      <div><span style="font-weight:600;">${fmtW(sweetBonus)}</span><br><span style="font-size:11px;color:#888;">甜蜜點獎金</span></div>
      <div><span style="font-weight:600;">${sweetGap >= 0 ? '+' : ''}${sweetGap.toFixed(1)}%</span><br><span style="font-size:11px;color:#888;">距甜蜜點</span></div>
      <div><span style="font-weight:600;">${marginalRate.toFixed(1)}%</span><br><span style="font-size:11px;color:#888;">邊際提撥率 ${actual > sweetSpot ? '(已過甜蜜點)' : '(甜蜜點前)'}</span></div>
      ${capHit ? '<div><span style="font-weight:600;color:#e67e22;">已達上限</span><br><span style="font-size:11px;color:#888;">超過 ${fmtW(capDeduction)}</span></div>' : ''}
    </div>
  `;
  document.getElementById('curveDetail').innerHTML = curveHtml;

  // 調節明細
  const abody = document.getElementById('adjustBody');
  let rows = [];
  rows.push(['原始佣金', fmtW(rawCommission), '—', fmtW(rawCommission)]);
  if (capHit) {
    rows.push(['封頂扣減', fmtW(rawCommission), '上限 ' + fmtW(bonusCap), fmtW(cappedCommission)]);
  }
  rows.push(['KPI 調節 (得分×權重)', fmtW(cappedCommission), (kpiScore * kpiWeight * 100).toFixed(0) + '%', fmtW(kpiAdjusted)]);
  if (behaviorMod !== 1.0) {
    rows.push(['行為職能係數', fmtW(kpiAdjusted), '×' + behaviorMod.toFixed(2), fmtW(behaviorAdjusted)]);
  }
  rows.push(['CSAT 品質門檻', fmtW(behaviorAdjusted), csatNote, fmtW(csatAdjusted)]);
  if (clawbackAmt > 0) {
    rows.push(['Clawback 追回', fmtW(csatAdjusted), '-' + fmtW(clawbackAmt), fmtW(csatAdjusted - clawbackAmt)]);
  }
  rows.push(['最終獎金', '', '', fmtW(finalBonus)]);
  abody.innerHTML = rows.map((r, i) => {
    const isLast = i === rows.length - 1;
    const isDed = r[2].startsWith('-') || r[0] === 'Clawback 追回' || r[0] === '封頂扣減';
    const cls = isLast ? 'total-row' : (isDed ? 'deduction-row' : '');
    return `<tr class="${cls}"><td>${r[0]}</td><td class="text-right">${r[1]}</td><td class="text-right">${r[2]}</td><td class="text-right">${r[3]}</td></tr>`;
  }).join('');

  // 財務健康
  let healthHtml = '<div class="health-meter">';

  const laborOk = laborRate <= 50;
  healthHtml += `<div class="health-item ${laborOk ? 'success-box' : 'danger-box'}">
    <div class="val">${laborRate.toFixed(1)}%</div>
    <div>勞動分配率 ${laborOk ? '健康 (≤50%)' : '過高 (>50%)'}</div>
  </div>`;

  const compaOk = compaRatio >= 0.8;
  healthHtml += `<div class="health-item ${compaOk ? 'success-box' : 'danger-box'}">
    <div class="val">${compaRatio.toFixed(2)}</div>
    <div>Compa-Ratio ${compaOk ? '正常' : '偏低 (<0.8)'}</div>
  </div>`;

  const wageOk = totalPayMonthly * 10000 >= 29500;
  healthHtml += `<div class="health-item ${wageOk ? 'success-box' : 'danger-box'}">
    <div class="val">${fmt(totalPayMonthly * 10000)}/月</div>
    <div>最低工資 ${wageOk ? '合規' : '低於 29,500'}</div>
  </div>`;

  healthHtml += `<div class="health-item success-box">
    <div class="val">${(totalPersonnelCost > 0 ? (actual / totalPersonnelCost).toFixed(1) : 0)}x</div>
    <div>營收/人事成本比</div>
  </div>`;

  healthHtml += '</div>';

  if (laborRate > 61) {
    healthHtml += '<div class="danger-box">勞動分配率超過 61%，經營警訊！需調整薪酬結構或提升毛利。</div>';
  }
  if (!wageOk) {
    healthHtml += '<div class="danger-box">扣回後月薪低於 29,500 元（2026 基本工資），違反勞基法！Clawback 需設上限。</div>';
  }
  if (capHit) {
    healthHtml += '<div class="warning-box">已觸及獎金上限 (上限 ' + fmtW(bonusCap) + ')。建議評估是否需要提高上限。</div>';
  }
  if (actual > sweetSpot && sweetSpot > 0) {
    healthHtml += '<div class="warning-box">實際業績已超過甜蜜點 (' + fmtW(sweetSpot) + ')，邊際提撥率已由 ' + (accelRate * 100).toFixed(1) + '% 降至 ' + (decelRate * 100).toFixed(1) + '%。</div>';
  }

  document.getElementById('healthCheck').innerHTML = healthHtml;
}

function loadExample() {
  document.getElementById('jobType').value = '上山型';
  document.getElementById('bonusType').value = 'commission';
  document.getElementById('baseSalary').value = 120;
  document.getElementById('targetBonus').value = 120;
  document.getElementById('overheadRate').value = 20;
  document.getElementById('quota').value = 1440;
  document.getElementById('actual').value = 1800;
  document.getElementById('cogsRate').value = 20;
  document.getElementById('grossMarginRate').value = 15;
  document.getElementById('kpiScore').value = 0.95;
  document.getElementById('kpiWeight').value = 100;
  document.getElementById('csatTarget').value = 4.5;
  document.getElementById('csatActual').value = 4.2;
  document.getElementById('csatPenalty').value = 10;
  document.getElementById('behaviorMod').value = 1.0;
  document.getElementById('cbAmount').value = 120;
  document.getElementById('cbRate').value = 10;
  document.getElementById('cbTotalMonths').value = 12;
  document.getElementById('cbFulfilledMonths').value = 4;
  document.getElementById('sweetSpot').value = 1500;
  document.getElementById('decelRate').value = 2;
  document.getElementById('bonusCap').value = 200;

  // 清除並新增階梯門檻
  document.getElementById('stepBody').innerHTML = '';
  addStepRow(400, 2);
  addStepRow(800, 3);
  addStepRow(1152, 5);
  addStepRow(1440, 8);

  curvePreview();
  calculate();
}

// 初始載入
window.addEventListener('DOMContentLoaded', function() {
  try {
    loadExample();
  } catch(e) {
    document.getElementById('healthCheck').innerHTML =
      '<div class="danger-box">JavaScript 錯誤：' + e.message + '<br>請按 Ctrl+Shift+R 重新整理頁面，或檢查瀏覽器 Console (F12)</div>';
    throw e;
  }
});
</script>
</body>
</html>
